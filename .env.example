# Copy to .env and fill in.  .env is gitignored — never commit real secrets.
#
# The stellar.expert Explorer API is READ-ONLY and works without a key.
# A key simply raises your rate limit. Get one from your stellar.expert
# account dashboard (requires an active API subscription tier).

# Bearer token from your stellar.expert account dashboard (optional).
STELLAR_EXPERT_API_KEY=

# Network segment: "public" (mainnet) or "testnet". Defaults to public.
STELLAR_NETWORK=public
